# ── Proxy (Brightdata) ────────────────────────────────────────────────────────
PROXY_HOST=brd.superproxy.io
PROXY_USER=brd-customer-hl_XXXXXXXX-zone-datacenter_proxy1
PROXY_PASS=your_proxy_password
PROXY_PORT_DC=22225
PROXY_PORT_RESIDENTIAL=33335

# ── GCS ───────────────────────────────────────────────────────────────────────
GCS_BUCKET=it-planet-output

# ── GCP ───────────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
FIRESTORE_PROJECT=your-gcp-project-id
CLOUD_TASKS_LOCATION=europe-west1
CLOUD_TASKS_QUEUE=it-planet-queue
CLOUD_TASKS_SA_EMAIL=it-planet-tasks@your-gcp-project-id.iam.gserviceaccount.com

# ── Auth ──────────────────────────────────────────────────────────────────────
API_KEY=your_secret_api_key

# ── Notifications ─────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=you@gmail.com
NOTIFICATION_EMAIL=client@example.com

# ── Worker URLs (set after Cloud Run deploy) ──────────────────────────────────
JACOB_WORKER_URL=https://jacob-worker-XXXX-ew.a.run.app
IT_RESELL_WORKER_URL=https://it-resell-worker-XXXX-ew.a.run.app
IT_MARKET_WORKER_URL=https://it-market-worker-XXXX-ew.a.run.app
TONITRUS_DISCOVERY_URL=https://tonitrus-XXXX-ew.a.run.app
TONITRUS_WORKER_URL=https://tonitrus-XXXX-ew.a.run.app
TONITRUS_MERGE_URL=https://tonitrus-XXXX-ew.a.run.app
